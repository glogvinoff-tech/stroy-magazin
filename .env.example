REACT_APP_API_BASE=http://127.0.0.1:8001/api
FRONTEND_PUBLIC_URL=http://localhost:3000

REACT_APP_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback


FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email verification SMTP.
# Fill these values in your local .env if verification codes must be sent to real email inboxes.
# For Gmail/Yandex/Mail.ru use an app password, not your normal mailbox password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-glogvinov89@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-glogvinov89@gmail.com

# 1 = if SMTP is empty, print the email code in the backend console.
# 0 = require real SMTP and return an error when it is not configured.
EMAIL_CODE_DEV_MODE=1
